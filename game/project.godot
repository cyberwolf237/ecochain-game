; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   option = value ; assign values to options

config_version=5

[application]
config/name="EcoChain"
config/version="1.0.0"
run/main_scene="res://scenes/main_menu.tscn"
config/features=PackedStringArray("4.0", "GL_TEXTURES_PVRTC")
config/icon="res://assets/images/icon.png"

[autoload]
GameManager="*res://scripts/game_manager.gd"

[display]
window/size/viewport_width=1280
window/size/viewport_height=720
window/handheld/orientation="portrait"

[physics]
physics_engine="GodotPhysics2D"

[rendering]
textures/canvas_textures/hdri_mode=true
renderer/rendering_method="mobile"
